# Backend environment variables
# Copy this file to .env and fill in your real values.
# NEVER commit the actual .env file.

# Neon Postgres — use the POOLED connection string (hostname contains "-pooler")
# Find it in: Neon Dashboard → your project → Connection Details → Pooled connection
DATABASE_URL=postgres://user:password@ep-xxx-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require

# The deployed frontend URL — used for CORS so the browser can reach this API
# Example: https://product-streamer.vercel.app
FRONTEND_URL=https://your-frontend-url.vercel.app

# Port the Express server listens on (Render sets this automatically)
PORT=3001
